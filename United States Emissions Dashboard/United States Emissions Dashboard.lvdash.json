{
  "datasets": [
    {
      "name": "14319c67",
      "displayName": "Location Data",
      "queryLines": [
        "SELECT latitude, longitude, 'GHG emissions mtons CO2e' as Emmisions FROM emissions.default.emissions_data_2023"
      ]
    },
    {
      "name": "f44a3f87",
      "displayName": "Emissions Per Person",
      "queryLines": [
        "SELECT county_state_name,\r\n",
        "       population,\r\n",
        "       CAST(\r\n",
        "           REPLACE(`GHG emissions mtons CO2e`, ',', '') \r\n",
        "           AS DOUBLE\r\n",
        "       ) / NULLIF(\r\n",
        "           CAST(\r\n",
        "               REPLACE(population, ',', '') \r\n",
        "               AS DOUBLE\r\n",
        "           ), \r\n",
        "           0\r\n",
        "       ) AS Emissions_per_person\r\n",
        "FROM emissions.default.emissions_data_2023\r\n",
        "ORDER BY emissions_per_person DESC"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "7dc01051",
      "displayName": "Total Emissions Per State",
      "queryLines": [
        "SELECT state_abbr,\r\n",
        "       SUM(\r\n",
        "           CAST(\r\n",
        "               REPLACE(`GHG emissions mtons CO2e`, ',', '') \r\n",
        "               AS DOUBLE\r\n",
        "           )\r\n",
        "       ) AS Total_Emissions\r\n",
        "FROM emissions_data_2023\r\n",
        "GROUP BY state_abbr\r\n",
        "ORDER BY Total_Emissions DESC\r\n",
        "LIMIT 10;"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "c5b02f28",
      "displayName": "Emissions Per County",
      "queryLines": [
        "SELECT county_state_name,\r\n",
        "       population,\r\n",
        "       CAST(\r\n",
        "           REPLACE(`GHG emissions mtons CO2e`, ',', '') \r\n",
        "           AS DOUBLE\r\n",
        "       ) AS Total_Emissions\r\n",
        "FROM emissions_data_2023\r\n",
        "ORDER BY Total_Emissions DESC\r\n",
        "LIMIT 10;"
      ],
      "catalog": "emissions",
      "schema": "default"
    }
  ],
